# ────────────────────────────────────────────────────────────────
# KKaudioBk — backend environment variables
# Copy to .env for local dev. NEVER commit a real .env file.
# In production, set each value in your hosting provider's
# secrets/env panel (Render, Railway, Fly, etc.).
# ────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Neon, Supabase, Railway, or local)
# Example Neon URL: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kkmusic

# JWT — generate a fresh 256-char hex string for each environment:
#   node -e "console.log(require('crypto').randomBytes(128).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-hex-string

# Email (transactional). Use Resend / SendGrid / Mailgun in prod;
# Gmail app passwords work for dev only.
EMAIL_USER=
EMAIL_PASS=

# Groq — for AI lyric generation
GROQ_API_KEY=

# CORS — comma-separated list of allowed origins
# Example: https://app.muves.in,https://muves.in,http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Default admin (only used the first time the admin_users table is
# seeded). Leave blank to skip auto-seeding entirely.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Super Admin
